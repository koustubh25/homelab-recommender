{
  "_schema": {
    "version": 1,
    "description": "Region → residential electricity rate used by energy-modeler. Rates are typical residential peak/flat rates as of late 2025 / early 2026, in local currency per kWh, tax-inclusive where local convention is tax-inclusive (e.g. AU GST). If a user provides their actual rate, prefer it over these defaults.",
    "lookup_order": [
      "exact match on requirements.region.country + requirements.region.state_or_city",
      "country-level _default_rate",
      "energy-modeler falls back to a guess and flags it in the report"
    ],
    "fields": {
      "rate": "Per-kWh price in local currency",
      "currency": "ISO-4217 currency code",
      "tax_inclusive": "True if rate already includes local sales tax (GST/VAT)",
      "source_note": "Where this estimate came from (regulator, retailer average, etc.)",
      "as_of": "Approximate date the rate was current; assume drift after 6 months"
    }
  },

